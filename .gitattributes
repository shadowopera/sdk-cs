# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Unity files
*.cs text eol=lf
*.meta text eol=lf
*.asmdef text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.shader text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.so binary
*.dylib binary

# Windows-specific files that require CRLF
*.sln      text eol=crlf
*.slnx     text eol=crlf
*.csproj   text eol=crlf
